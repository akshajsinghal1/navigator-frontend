# ── Tableau Cloud credentials ─────────────────────────────────────────────────
TABLEAU_SERVER_URL=https://us-east-1.online.tableau.com
TABLEAU_SITE_NAME=your-site-name
TABLEAU_PAT_NAME=your-personal-access-token-name
TABLEAU_PAT_SECRET=your-personal-access-token-secret

# ── Gemini API ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Optional: Redis cache (falls back to file-based if not set) ───────────────
# REDIS_URL=redis://localhost:6379

# ── Optional: Database (defaults to SQLite navigator.db) ─────────────────────
# DATABASE_URL=postgresql://user:password@localhost/navigator

# ── System Admin Backend (backend/) — port 8001 ───────────────────────────────
# Copy backend/.env.example to backend/.env and fill in:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=
# APP_URL=http://localhost:5174
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=

# ── System Admin Frontend (frontend-admin/) — port 5174 ───────────────────────
# Copy frontend-admin/.env.example to frontend-admin/.env and fill in:
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=
